# =============================================================================
# KORS — Variables d'environnement locales (dev uniquement)
# NE PAS committer ce fichier avec de vraies credentials en production
# =============================================================================

# --- Projet ---
COMPOSE_PROJECT_NAME=kors

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kors
POSTGRES_USER=kors
POSTGRES_PASSWORD=kors_dev_secret

# --- TimescaleDB (meme instance PostgreSQL, extension activee) ---
# TimescaleDB tourne comme extension sur le meme conteneur PostgreSQL
# Pas de variables supplementaires necessaires

# --- NATS ---
NATS_HOST=nats
NATS_PORT=4222
NATS_WS_PORT=8080
NATS_MONITOR_PORT=8222
NATS_CLUSTER_NAME=kors-local

# --- MinIO ---
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=kors_minio
MINIO_ROOT_PASSWORD=kors_minio_secret
MINIO_DEFAULT_BUCKET=kors-assets

# --- Keycloak ---
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_secret
KEYCLOAK_REALM=kors
KEYCLOAK_CLIENT_ID=kors-bff
KEYCLOAK_CLIENT_SECRET=kors_bff_client_secret_dev

# --- Traefik ---
TRAEFIK_DASHBOARD_PORT=8090

# --- URLs locales (utilisees par les services Go) ---
DATABASE_URL=postgres://kors:kors_dev_secret@postgres:5432/kors?sslmode=disable
NATS_URL=nats://nats:4222
MINIO_ENDPOINT=minio:9000
KEYCLOAK_ISSUER=http://keycloak:8080/realms/kors
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/kors/protocol/openid-connect/certs
